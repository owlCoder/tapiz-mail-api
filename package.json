{
  "name": "tapiz-mail-service",
  "version": "2.0.0",
  "description": "Tapiz mail service — Hono + TypeScript",
  "scripts": {
    "dev":       "nodemon --exec ts-node --project tsconfig.json src/index.ts",
    "start":     "node dist/src/index.js",
    "build":     "tsc",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@hono/node-server": "^2.0.2",
    "dotenv":            "^17.4.2",
    "hono":              "^4.12.18",
    "hono-rate-limiter": "^0.5.3",
    "ioredis":           "^5.10.1",
    "nodemailer":        "^8.0.7"
  },
  "devDependencies": {
    "@types/node":       "^25.8.0",
    "@types/nodemailer": "^8.0.0",
    "nodemon":           "^3.1.14",
    "ts-node":           "^10.9.2",
    "typescript":        "^6.0.3"
  },
  "engines": {
    "node": ">=18"
  }
}
